# OpenAI API Key (or LiteLLM proxy key)
OPENAI_API_KEY=your_api_key_here

# LiteLLM proxy base URL (optional — omit to use OpenAI directly)
# OPENAI_BASE_URL=http://localhost:4000

# Model overrides (optional — defaults: gpt-4o for editor, gpt-4o-mini for suggestions)
# EDITOR_MODEL=openai/gpt-4o
# SUGGESTIONS_MODEL=openai/gpt-4o-mini

# Dify Agent API
# Get your API key from: Dify dashboard > Your App > API Access
DIFY_API_KEY=app-your-dify-api-key-here
DIFY_API_BASE_URL=https://api.dify.ai
